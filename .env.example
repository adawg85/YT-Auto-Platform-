# ══════════════════════════════════════════════════════════════════════════
# RUN LOCAL LIKE PROD (real providers, not mocks) — see docs/LOCAL.md
#   1. docker compose up -d && pnpm db:migrate
#   2. In this .env set: SECRETS_ENCRYPTION_KEY, OPERATOR_USER/PASS, and the
#      two REAL-MODE flags (uncommented below): RESEARCH_PROVIDER=youtube and
#      SOURCE_CONNECTORS=real.
#   3. Start worker + cockpit (env loaded), then add provider keys on /account:
#      ANTHROPIC_API_KEY (covers ALL LLM tiers — no LLM_MODEL_* pinning needed),
#      ELEVENLABS_API_KEY, FAL_KEY. Restart both so they pick the keys up.
# Local DB + object store are SEPARATE from prod (different content, local disk),
# by design. Code stays aligned via git: work on main, pull, push to deploy.
# ══════════════════════════════════════════════════════════════════════════

# ── Core ────────────────────────────────────────────────────────────────
# Postgres connection string
DATABASE_URL=postgres://ytauto:ytauto@localhost:5432/ytauto

# Cockpit basic auth (single operator)
OPERATOR_USER=operator
OPERATOR_PASS=change-me

# Master passphrase for provider keys saved on the /account page
# (AES-256-GCM at rest). Generate: openssl rand -hex 32
# Rotating it orphans stored keys — re-enter them on /account afterwards.
SECRETS_ENCRYPTION_KEY=change-me-openssl-rand-hex-32

# Next.js Server Actions encryption key. PIN THIS in production: without it,
# every `docker compose up -d --build` regenerates the key and already-open
# tabs get "Server Action not found" (UnrecognizedActionError). Must be present
# at BUILD time (baked into the client bundle — compose passes it as a build
# arg) AND at runtime. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=change-me-base64-32-bytes

# ── Droplet prod edge (docker-compose.prod.yml + deploy/Caddyfile) ────────
# Public URL the cockpit is reached at. REQUIRED behind the reverse proxy for
# OAuth: Next otherwise resolves its origin to the internal https://localhost:3000,
# so the Google redirect_uri won't match the one you registered. Set this to the
# full https URL (scheme + host, no trailing slash, no path). The YouTube OAuth
# redirect becomes <PUBLIC_BASE_URL>/api/oauth/youtube/callback — register EXACTLY
# that in the Google Cloud Console OAuth client.
#PUBLIC_BASE_URL=https://app.example.com
# Hostname the cockpit is served on; Caddy auto-issues HTTPS for it.
#COCKPIT_DOMAIN=app.example.com
# Optional: comma-separated hostnames that 301-redirect to COCKPIT_DOMAIN
# (e.g. the bare root + www). Each must also resolve to this droplet.
#COCKPIT_REDIRECT_FROM=example.com, www.example.com

# ── Object storage ──────────────────────────────────────────────────────
# If S3_* are unset, a local filesystem store is used (STORE_DIR below).
# For DigitalOcean Spaces: S3_ENDPOINT=https://<region>.digitaloceanspaces.com
#S3_ENDPOINT=http://localhost:9000
#S3_BUCKET=ytauto
#S3_ACCESS_KEY_ID=
#S3_SECRET_ACCESS_KEY=
#S3_REGION=us-east-1
STORE_DIR=./data/store

# ── Providers ───────────────────────────────────────────────────────────
# Each provider falls back to a deterministic mock when its key is unset.
# Set PROVIDERS_FORCE_MOCK=1 to force mocks even when keys are present.
#PROVIDERS_FORCE_MOCK=1

# LLMs — direct vendor keys, chosen by us (no gateway upstream lottery).
# All keys + tier models are also settable on /account (account values win,
# apply instantly). Model refs are vendor-prefixed:
#   anthropic:claude-opus-4-8   openai:gpt-5   google:gemini-2.5-flash-lite
#   glm:glm-4.6   qwen:qwen-plus   kimi:kimi-k2-turbo-preview
#   openrouter:anthropic/claude-opus-4.8   (bare ids = OpenRouter slugs)
# OPENAI_API_KEY (below, in the embeddings block) also powers the openai: LLM
# vendor — set it once and use e.g. openai:gpt-5 as a tier model.
# Where it makes sense: Claude = scripting/charters (frontier+agentic);
# Gemini/GLM/Qwen/Kimi = cheap + bulk agentic work; OpenRouter = fallback.
# NOTE: the tier LLM_MODEL_* below are OPTIONAL — the router degrades to any key
# you hold, so a single ANTHROPIC_API_KEY lights up all three tiers on its own.
# Only pin LLM_MODEL_* if you want a specific model per tier.
#ANTHROPIC_API_KEY=
#GEMINI_API_KEY=
#ZAI_API_KEY=
#DASHSCOPE_API_KEY=
#MOONSHOT_API_KEY=
#OPENROUTER_API_KEY=
#LLM_MODEL_CHEAP=google:gemini-2.5-flash-lite
#LLM_MODEL_AGENTIC=anthropic:claude-sonnet-5
#LLM_MODEL_FRONTIER=anthropic:claude-opus-4-8
# Endpoint overrides for the OpenAI-compatible direct vendors (rarely needed;
# defaults: Z.ai api.z.ai, DashScope intl compatible-mode, Moonshot api.moonshot.ai)
#ZAI_BASE_URL=
#DASHSCOPE_BASE_URL=
#MOONSHOT_BASE_URL=

# Voice / TTS (ElevenLabs)
#ELEVENLABS_API_KEY=
# Default voice id used when a channel's voice is unset/"default". Copy a Voice
# ID from your ElevenLabs dashboard (Voices → a voice → ID). Falls back to the
# "Rachel" premade voice if unset. Optional model override too.
#ELEVENLABS_VOICE_ID=
#ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Media generation (fal.ai)
#FAL_KEY=

# Research / competitive intelligence — powers the build #4 meta-analysis engine
# (outliers, breakout channels, trending, transcripts). Pick a backend:
#   unset / "mock" → deterministic fixtures (zero keys, offline, CI default)
#   "youtube"      → MIT, free, keyless via youtubei.js (InnerTube). Outlier &
#                    velocity scores are computed in-house; keyword search volume
#                    is unavailable (YouTube doesn't expose it). Recommended real
#                    backend. Note: scrapes an unofficial API (ToS-gray).
#   "vidiq"        → premium; needs VIDIQ_API_KEY. Adds keyword search volume and
#                    ready-made breakout/outlier scoring. Speaks vidIQ's MCP server.
#RESEARCH_PROVIDER=youtube
# vidIQ (only when RESEARCH_PROVIDER=vidiq):
#VIDIQ_API_KEY=
# Override if vidIQ's MCP endpoint differs from the default:
#VIDIQ_MCP_URL=https://mcp.vidiq.com/mcp

# ── Editorial engine (build #5) ─────────────────────────────────────────
# Source connectors (per-channel truth sources: RSS / web pages / YouTube).
# rss+web are keyless, so real is explicit opt-in — unset stays mocked/offline.
#SOURCE_CONNECTORS=real
# Embeddings for the pgvector semantic memory. Key present → OpenAI
# text-embedding-3-small (1536 dims); absent → deterministic mock.
#OPENAI_API_KEY=

# YouTube publishing (OAuth per channel; v1 single-token via env)
#YOUTUBE_CLIENT_ID=
#YOUTUBE_CLIENT_SECRET=
#YOUTUBE_REFRESH_TOKEN=
# Daily API quota for upload scheduling (default 10000 units; upload ~1600)
#YOUTUBE_DAILY_QUOTA=10000

# ── Inngest ─────────────────────────────────────────────────────────────
# Dev: `npx inngest-cli dev` needs no keys. Prod (inngest start) needs:
#INNGEST_EVENT_KEY=
#INNGEST_SIGNING_KEY=
INNGEST_BASE_URL=http://localhost:8288

# ── Worker / render ─────────────────────────────────────────────────────
WORKER_PORT=3010
# Optional explicit chromium for Remotion (e.g. sandboxes with preinstalled browser)
#REMOTION_BROWSER_EXECUTABLE=/opt/pw-browsers/chromium/chrome
# $/hour rate used to attribute render compute cost to videos
RENDER_COST_PER_HOUR=0.06
