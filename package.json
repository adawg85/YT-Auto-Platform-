{
  "name": "yt-auto-platform",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @ytauto/db generate",
    "db:migrate": "pnpm --filter @ytauto/db migrate",
    "db:seed": "pnpm --filter @ytauto/db seed"
  },
  "devDependencies": {
    "turbo": "^2.10.2",
    "typescript": "^5.9.3"
  }
}
